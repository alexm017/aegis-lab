# Copy this file to .env and set real values.

# Dashboard admin bcrypt hash (required for /dashboard login).
# Example generation:
# php -r 'echo password_hash("CHANGE_ME", PASSWORD_BCRYPT), PHP_EOL;'
ZS_ADMIN_PASSWORD_HASH=

# Optional assistant chat integration key.
OPENAI_API_KEY=

# Optional legacy key name supported by current code.
openai_token=

# Optional log path overrides for CTF analytics.
AEGIS_CTF_ACCESS_LOG=
AEGIS_CTF_CHALLENGE_LOG_MAP=

# Optional sitemap base URL override.
SITEMAP_BASE_URL=https://aegislab.ro
